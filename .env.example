ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI
ADMIN_EMAIL=votre.email@exemple.com

# Supabase — base de données + clé anonyme.
# ⚠️ SUPABASE_ANON_KEY est OBLIGATOIRE : elle sert aussi de secret de signature des
# tokens de session (HMAC). Sans elle, l'application refuse de démarrer.
# Le nom de variable DOIT être SUPABASE_ANON_KEY (et non SUPABASE_KEY).
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_ANON_KEY=votre_cle_anon_supabase_ici

# Email transactionnel — SMTP Hostinger (SSL/465)
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=contact@tiktokshop-analyzer.com
SMTP_PASSWORD=votre_mot_de_passe_smtp_ici
SMTP_FROM_NAME=TikTok Shop Analyzer
SUPPORT_EMAIL=contact@tiktokshop-analyzer.com
APP_PUBLIC_URL=https://tiktokshop-analyzer.com

# CAPTCHA anti-bot — Cloudflare Turnstile (protège la création de compte)
# Laisser vide = CAPTCHA désactivé (l'app fonctionne normalement).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_RATE_LIMIT=5
TEMPORARY_PASSWORD_LENGTH=12

# Stripe — abonnements (checkout désactivé tant que la société n'est pas créée)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Prix mensuels
STRIPE_PRICE_PRO=
STRIPE_PRICE_GOLD=
STRIPE_PRICE_AGENCY=
# Prix annuels (2 mois offerts = paiement de 10 mois pour 12)
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_GOLD_YEAR=
STRIPE_PRICE_AGENCY_YEAR=

# OAuth TikTok — Login Kit / Display API (TikTok for Developers — cible CRÉATEURS)
# App enregistrée sur developers.tiktok.com (≠ Business API). Clés jamais en dur.
TIKTOK_APP_ID=                 # = client_key du Login Kit
TIKTOK_APP_SECRET=             # client secret du Login Kit
# Optionnel : surcharge scopes / endpoints / redirect (valeurs par défaut sinon).
# Le redirect doit correspondre EXACTEMENT à celui configuré dans l'app TikTok :
#   https://tiktokshop-analyzer.com/api/auth/tiktok/callback
TIKTOK_REDIRECT_URI=
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats,video.list
TIKTOK_AUTHORIZE_URL=https://www.tiktok.com/v2/auth/authorize/
TIKTOK_TOKEN_URL=https://open.tiktokapis.com/v2/oauth/token/
TIKTOK_REFRESH_URL=https://open.tiktokapis.com/v2/oauth/token/
TIKTOK_API_BASE=https://open.tiktokapis.com/v2

# OAuth TikTok BUSINESS (Marketing API — insights audience). 2ème app (business-api).
TIKTOK_BIZ_APP_ID=
TIKTOK_BIZ_APP_SECRET=
TIKTOK_BIZ_SCOPES=user.info.basic,biz.creator.info,biz.creator.insights,user.info.username,user.info.stats,user.account.type,user.insights
TIKTOK_BIZ_AUTHORIZE_URL=https://www.tiktok.com/v2/auth/authorize/
TIKTOK_BIZ_TOKEN_URL=https://business-api.tiktok.com/open_api/v1.3/tt_user/oauth2/token/
TIKTOK_BIZ_REFRESH_URL=https://business-api.tiktok.com/open_api/v1.3/tt_user/oauth2/refresh_token/
TIKTOK_BIZ_API_BASE=https://business-api.tiktok.com/open_api/v1.3
# Champs /business/get/ (audience + métriques) — ajustables sans toucher au code
TIKTOK_BIZ_FIELDS=display_name,profile_image,followers_count,audience_countries,audience_genders,audience_ages,audience_activity,video_views,likes,comments,shares
# Vérification de propriété du domaine (méthode balise meta) — code donné par TikTok
TIKTOK_SITE_VERIFICATION=
# Vérification « préfixe d'URL » (fichier de signature) — nom + contenu du fichier TikTok
TIKTOK_VERIFY_FILENAME=
TIKTOK_VERIFY_CONTENT=
